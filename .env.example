# Railway Backend Environment Variables
# Copy this file to .env and fill in the values

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Primary LLM provider: Google Gemini OpenAI-compatible API
LLM_API_KEY=your_gemini_api_key_here
LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_MODEL=gemini-2.5-flash

# Fallback LLM provider: Cerebras OpenAI-compatible API
LLM_FALLBACK_API_KEY=your_cerebras_api_key_here
LLM_FALLBACK_ENDPOINT=https://api.cerebras.ai/v1/chat/completions
LLM_FALLBACK_MODEL=qwen-3-235b-a22b-instruct-2507

# Emergency LLM provider: OpenRouter free-model router
LLM_EMERGENCY_API_KEY=your_openrouter_api_key_here
LLM_EMERGENCY_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
LLM_EMERGENCY_MODEL=openrouter/free

# Optional. Disabled by default for wider compatibility with free APIs.
LLM_RESPONSE_FORMAT=false
LLM_REQUEST_RETRIES=1
OPT_MAX_ATTEMPTS=2
OPT_MIN_AUDIT_SCORE=85
OPT_TEMPERATURE=0.15

ADMIN_EMAILS=admin@example.com,second@example.com
HH_USER_AGENT=ResumeOptimizer/1.0 (your-real-email@domain.ru)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://resume-optimizer-diplom.vercel.app,https://resume-optimizer-diplom-vitalik4384-2488s-projects.vercel.app
JOB_TEXT_ALLOWED_HOSTS=hh.ru,hh.kz,hh.uz,hh.kg
RATE_LIMIT_WINDOW_SECONDS=60
JOB_TEXT_RATE_LIMIT=30
OPTIMIZE_RATE_LIMIT=10
PORT=3000
